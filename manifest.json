  "commercial_model": {
    "transport": "x402-first",
    "receipts": "canonical commercial receipt artifacts",
    "runtime_scope": "execution, metering, and provider policy remain out of scope",
    "actor_grammar": "payer funds value, payee receives authorization settlement direction, merchant defines the contract, provider executes for the merchant, carrier emits shipment state, verifier asserts verification truth.",
    "x402_grammar": "payment_requirement expresses pre-payment terms, payment_session expresses live settlement state, and payment_proof expresses final captured settlement evidence."
  },
  "aligns_with": {
    "protocol_commons": "1.1.0",
    "agent_cards": "1.1.0"
  },
  "verbs": [
